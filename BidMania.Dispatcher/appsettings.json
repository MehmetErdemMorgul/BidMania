{
  "ReverseProxy": {
    "Routes": {
      "product-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/products/{**remainder}" }
      },
      "auction-route": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/auctions/{**remainder}" }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**remainder}" }
      }
    },
    "Clusters": {
      "auction-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5183" } }
      },
      "auth-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5000" } }
      }
    }
  }
}