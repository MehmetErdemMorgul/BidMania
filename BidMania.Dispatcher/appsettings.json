{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auction-route": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/api/auctions/{**remainder}"
        }
      }
    },
    "Clusters": {
      "auction-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5183"
          }
        }
      }
    }
  }
}